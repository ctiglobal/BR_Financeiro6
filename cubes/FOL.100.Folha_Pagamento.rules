SKIPCHECK;

# --------------------------------------------------------------------------------------------
#Name  Módulo Folha de Pagamento — Realizado (carga) + Projeção (Existentes x Novos)
#Desc  RE e versões estáticas (F1..F11) ficam como input (STET). Nas versões dinâmicas (T1/T2,
#      descendentes de 'Dynamic Versions'), gate Real x Orçado via REC.000: se o mês está marcado
#      'Real', a célula espelha RE; senão projeta. Referências a período anterior/seguinte usam o
#      cubo SYS.200.Time_Travel (não aritmética de string). Encargos sobre Salário+13º+Férias;
#      provisões 13º = Salário/12 e Férias = Salário/9.
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------

# --------------------------------------------------------------------------------------------
#Name  Escopo de cálculo por versão
#Desc  Só calcula nas versões dinâmicas (descendentes de 'Dynamic Versions' = T1/T2). RE e as
#      estáticas F1..F11 permanecem como valor digitado/carregado (STET).
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
[]=IF( ELISANC( 'ALL.D.Versao', 'Dynamic Versions', !ALL.D.Versao ) <> 0, CONTINUE, STET );

# --------------------------------------------------------------------------------------------
#Name  Premissas de folha (% de FOL.010)
#Desc  Dissídio, reajustes de benefícios e alíquotas de encargo vêm do cubo de premissas FOL.010
#      para a versão corrente.
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
['% Dissídio']=N:
   DB('FOL.010.Premissas_Gerais', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, '% Dissídio');
['% Reajuste Plano de Saúde']=N:
   DB('FOL.010.Premissas_Gerais', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, '% Reajuste Plano de Saúde');
['% Reajuste Vale Refeição']=N:
   DB('FOL.010.Premissas_Gerais', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, '% Reajuste Vale Refeição');
['% INSS']=N:
   DB('FOL.010.Premissas_Gerais', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, '% INSS');
['% FGTS']=N:
   DB('FOL.010.Premissas_Gerais', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, '% FGTS');

# --------------------------------------------------------------------------------------------
#Name  Saldo Inicial HC
#Desc  Real espelha RE; Orçado = Saldo Final HC do mês anterior (período anterior obtido em
#      SYS.200.Time_Travel com Parametro_Mes '-1').
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
['Saldo Inicial HC']=N:
   IF( DB('REC.000.Controle_Real_Orcado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, 'Real ou Orçado') @= 'Real',
      DB('FOL.100.Folha_Pagamento', !ALL.D.Ano, !ALL.D.Mes, 'RE', !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, 'Saldo Inicial HC'),
      DB('FOL.100.Folha_Pagamento',
         DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Ano'),
         DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Mes'),
         !ALL.D.Versao, !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, 'Saldo Final HC' ) );

# --------------------------------------------------------------------------------------------
#Name  Saldo Final HC
#Desc  Real espelha RE; Orçado = Saldo Inicial HC + Contratações − Desligamentos (inputs).
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
['Saldo Final HC']=N:
   IF( DB('REC.000.Controle_Real_Orcado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, 'Real ou Orçado') @= 'Real',
      DB('FOL.100.Folha_Pagamento', !ALL.D.Ano, !ALL.D.Mes, 'RE', !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, 'Saldo Final HC'),
      ['Saldo Inicial HC'] + ['Contratações (Input)'] - ['Desligamentos (Input)'] );

# --------------------------------------------------------------------------------------------
#Name  $ Salário Base (valor unitário)
#Desc  Real = $ Salário / Saldo Final HC. Orçado: rola o Salário Base do mês anterior
#      (SYS.200.Time_Travel '-1') × (1 + % Dissídio) — assim o reajuste é PERMANENTE e compõe nos
#      meses seguintes. Quando não há base no mês anterior (1º mês da posição), semeia do Mapa
#      (ATTRN de ALL.D.Cargos) para Novos; Existentes sem base anterior = 0.
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
['$ Salário Base']=N:
   IF( DB('REC.000.Controle_Real_Orcado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, 'Real ou Orçado') @= 'Real',
      IF( ['Saldo Final HC'] <> 0, ['$ Salário'] / ['Saldo Final HC'], 0 ),
      IF( DB('FOL.100.Folha_Pagamento',
            DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Ano'),
            DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Mes'),
            !ALL.D.Versao, !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Salário Base' ) <> 0,
         DB('FOL.100.Folha_Pagamento',
            DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Ano'),
            DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Mes'),
            !ALL.D.Versao, !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Salário Base' ) * ( 1 + ['% Dissídio'] ),
         IF( !ALL.D.Existente_Novo @= 'Novos',
            ATTRN('ALL.D.Cargos', !ALL.D.Cargos, '$ Salário Base') * ( 1 + ['% Dissídio'] ),
            0 ) ) );

# --------------------------------------------------------------------------------------------
#Name  $ Valor Unitário Plano de Saúde
#Desc  Real = $ Plano de Saúde / Saldo Final HC. Orçado: rola do mês anterior (SYS.200.Time_Travel
#      '-1') × (1 + % Reajuste Plano de Saúde) — reajuste permanente. Sem valor no mês anterior
#      (1º mês), semeia do Mapa para Novos; Existentes = 0.
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
['$ Valor Unitário Plano de Saúde']=N:
   IF( DB('REC.000.Controle_Real_Orcado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, 'Real ou Orçado') @= 'Real',
      IF( ['Saldo Final HC'] <> 0, ['$ Plano de Saúde'] / ['Saldo Final HC'], 0 ),
      IF( DB('FOL.100.Folha_Pagamento',
            DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Ano'),
            DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Mes'),
            !ALL.D.Versao, !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Valor Unitário Plano de Saúde' ) <> 0,
         DB('FOL.100.Folha_Pagamento',
            DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Ano'),
            DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Mes'),
            !ALL.D.Versao, !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Valor Unitário Plano de Saúde' ) * ( 1 + ['% Reajuste Plano de Saúde'] ),
         IF( !ALL.D.Existente_Novo @= 'Novos',
            ATTRN('ALL.D.Cargos', !ALL.D.Cargos, '$ Plano de Saúde') * ( 1 + ['% Reajuste Plano de Saúde'] ),
            0 ) ) );

# --------------------------------------------------------------------------------------------
#Name  $ Valor Unitário Vale Refeição
#Desc  Real = $ Vale Refeição / Saldo Final HC. Orçado: rola do mês anterior (SYS.200.Time_Travel
#      '-1') × (1 + % Reajuste Vale Refeição) — reajuste permanente. Sem valor no mês anterior
#      (1º mês), semeia do Mapa para Novos; Existentes = 0.
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
['$ Valor Unitário Vale Refeição']=N:
   IF( DB('REC.000.Controle_Real_Orcado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, 'Real ou Orçado') @= 'Real',
      IF( ['Saldo Final HC'] <> 0, ['$ Vale Refeição'] / ['Saldo Final HC'], 0 ),
      IF( DB('FOL.100.Folha_Pagamento',
            DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Ano'),
            DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Mes'),
            !ALL.D.Versao, !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Valor Unitário Vale Refeição' ) <> 0,
         DB('FOL.100.Folha_Pagamento',
            DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Ano'),
            DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Mes'),
            !ALL.D.Versao, !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Valor Unitário Vale Refeição' ) * ( 1 + ['% Reajuste Vale Refeição'] ),
         IF( !ALL.D.Existente_Novo @= 'Novos',
            ATTRN('ALL.D.Cargos', !ALL.D.Cargos, '$ Vale Refeição') * ( 1 + ['% Reajuste Vale Refeição'] ),
            0 ) ) );

# --------------------------------------------------------------------------------------------
#Name  $ Salário
#Desc  Real espelha RE; Orçado = $ Salário Base × Saldo Final HC.
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
['$ Salário']=N:
   IF( DB('REC.000.Controle_Real_Orcado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, 'Real ou Orçado') @= 'Real',
      DB('FOL.100.Folha_Pagamento', !ALL.D.Ano, !ALL.D.Mes, 'RE', !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Salário'),
      ['$ Salário Base'] * ['Saldo Final HC'] );

# --------------------------------------------------------------------------------------------
#Name  $ Plano de Saúde
#Desc  Real espelha RE; Orçado = $ Valor Unitário Plano de Saúde × Saldo Final HC.
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
['$ Plano de Saúde']=N:
   IF( DB('REC.000.Controle_Real_Orcado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, 'Real ou Orçado') @= 'Real',
      DB('FOL.100.Folha_Pagamento', !ALL.D.Ano, !ALL.D.Mes, 'RE', !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Plano de Saúde'),
      ['$ Valor Unitário Plano de Saúde'] * ['Saldo Final HC'] );

# --------------------------------------------------------------------------------------------
#Name  $ Vale Refeição
#Desc  Real espelha RE; Orçado = $ Valor Unitário Vale Refeição × Saldo Final HC.
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
['$ Vale Refeição']=N:
   IF( DB('REC.000.Controle_Real_Orcado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, 'Real ou Orçado') @= 'Real',
      DB('FOL.100.Folha_Pagamento', !ALL.D.Ano, !ALL.D.Mes, 'RE', !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Vale Refeição'),
      ['$ Valor Unitário Vale Refeição'] * ['Saldo Final HC'] );

# --------------------------------------------------------------------------------------------
#Name  $ Provisão 13º Salário
#Desc  Real espelha RE; Orçado = $ Salário / 12.
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
['$ Provisão 13º Salário']=N:
   IF( DB('REC.000.Controle_Real_Orcado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, 'Real ou Orçado') @= 'Real',
      DB('FOL.100.Folha_Pagamento', !ALL.D.Ano, !ALL.D.Mes, 'RE', !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Provisão 13º Salário'),
      ['$ Salário'] / 12 );

# --------------------------------------------------------------------------------------------
#Name  $ Provisão Férias
#Desc  Real espelha RE; Orçado = $ Salário / 9.
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
['$ Provisão Férias']=N:
   IF( DB('REC.000.Controle_Real_Orcado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, 'Real ou Orçado') @= 'Real',
      DB('FOL.100.Folha_Pagamento', !ALL.D.Ano, !ALL.D.Mes, 'RE', !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Provisão Férias'),
      ['$ Salário'] / 9 );

# --------------------------------------------------------------------------------------------
#Name  $ INSS
#Desc  Real espelha RE; Orçado = (Salário + Provisão 13º + Provisão Férias) × % INSS.
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
['$ INSS']=N:
   IF( DB('REC.000.Controle_Real_Orcado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, 'Real ou Orçado') @= 'Real',
      DB('FOL.100.Folha_Pagamento', !ALL.D.Ano, !ALL.D.Mes, 'RE', !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ INSS'),
      ( ['$ Salário'] + ['$ Provisão 13º Salário'] + ['$ Provisão Férias'] ) * ['% INSS'] );

# --------------------------------------------------------------------------------------------
#Name  $ FGTS
#Desc  Real espelha RE; Orçado = (Salário + Provisão 13º + Provisão Férias) × % FGTS.
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
['$ FGTS']=N:
   IF( DB('REC.000.Controle_Real_Orcado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, 'Real ou Orçado') @= 'Real',
      DB('FOL.100.Folha_Pagamento', !ALL.D.Ano, !ALL.D.Mes, 'RE', !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ FGTS'),
      ( ['$ Salário'] + ['$ Provisão 13º Salário'] + ['$ Provisão Férias'] ) * ['% FGTS'] );

# --------------------------------------------------------------------------------------------
#Name  $ Saldo 13º Salário a Pagar
#Desc  Real espelha RE; Orçado = saldo do mês anterior (SYS.200.Time_Travel '-1') + Provisão 13º
#      − Pagamento 13º + Correção do saldo.
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
['$ Saldo 13º Salário a Pagar']=N:
   IF( DB('REC.000.Controle_Real_Orcado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, 'Real ou Orçado') @= 'Real',
      DB('FOL.100.Folha_Pagamento', !ALL.D.Ano, !ALL.D.Mes, 'RE', !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Saldo 13º Salário a Pagar'),
      DB('FOL.100.Folha_Pagamento',
         DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Ano'),
         DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Mes'),
         !ALL.D.Versao, !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Saldo 13º Salário a Pagar' )
      + ['$ Provisão 13º Salário'] - ['$ Pagamento 13º Salário'] + ['$ Correção Saldo 13º Salário'] );

# --------------------------------------------------------------------------------------------
#Name  $ Saldo Férias a Pagar
#Desc  Real espelha RE; Orçado = saldo do mês anterior (SYS.200.Time_Travel '-1') + Provisão Férias
#      − Pagamento Férias + Correção do saldo.
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
['$ Saldo Férias a Pagar']=N:
   IF( DB('REC.000.Controle_Real_Orcado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, 'Real ou Orçado') @= 'Real',
      DB('FOL.100.Folha_Pagamento', !ALL.D.Ano, !ALL.D.Mes, 'RE', !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Saldo Férias a Pagar'),
      DB('FOL.100.Folha_Pagamento',
         DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Ano'),
         DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '-1', 'Mes'),
         !ALL.D.Versao, !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Saldo Férias a Pagar' )
      + ['$ Provisão Férias'] - ['$ Pagamento Férias'] + ['$ Correção Saldo Férias a Pagar'] );


# --------------------------------------------------------------------------------------------
#Name  FEEDERS
#Desc  Feeder de versão (RE alimenta as dinâmicas). Cadeia Orçado: Saldo Final HC e $ Salário
#      alimentam os derivados da mesma célula; inputs de movimentação alimentam o Saldo Final HC;
#      roll cross-mês (M → M+1) via SYS.200.Time_Travel (Parametro_Mes '1').
#Date  08/07/2026
#Author CTI Global
# --------------------------------------------------------------------------------------------
FEEDERS;

# --- Caminho Real: RE alimenta as versões dinâmicas T1/T2 ---
['ALL.D.Versao':'ALL.D.Versao':'RE'] => ['ALL.D.Versao':'ALL.D.Versao':'Dynamic Versions'];

# --- Caminho Orçado: HC e Salário alimentam os derivados na mesma célula ---
['Saldo Inicial HC'] => ['Saldo Final HC'];
['Contratações (Input)'] => ['Saldo Final HC'];
['Desligamentos (Input)'] => ['Saldo Final HC'];
['Saldo Final HC'] => ['$ Salário Base'], ['$ Salário'],
   ['$ Valor Unitário Plano de Saúde'], ['$ Plano de Saúde'],
   ['$ Valor Unitário Vale Refeição'], ['$ Vale Refeição'],
   ['% Dissídio'], ['% Reajuste Plano de Saúde'], ['% Reajuste Vale Refeição'], ['% INSS'], ['% FGTS'];
['$ Salário'] => ['$ Provisão 13º Salário'], ['$ Provisão Férias'], ['$ INSS'], ['$ FGTS'],
   ['$ Saldo 13º Salário a Pagar'], ['$ Saldo Férias a Pagar'];

# --- Caminho Orçado: roll cross-mês (M alimenta M+1) via SYS.200.Time_Travel ---
['Saldo Final HC'] =>
   DB('FOL.100.Folha_Pagamento',
      DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '1', 'Ano'),
      DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '1', 'Mes'),
      !ALL.D.Versao, !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, 'Saldo Inicial HC' );
['$ Saldo 13º Salário a Pagar'] =>
   DB('FOL.100.Folha_Pagamento',
      DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '1', 'Ano'),
      DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '1', 'Mes'),
      !ALL.D.Versao, !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Saldo 13º Salário a Pagar' );
['$ Saldo Férias a Pagar'] =>
   DB('FOL.100.Folha_Pagamento',
      DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '1', 'Ano'),
      DB('SYS.200.Time_Travel', !ALL.D.Ano, !ALL.D.Mes, '1', 'Mes'),
      !ALL.D.Versao, !ALL.D.Existente_Novo, !ALL.D.Centro_Custo, !ALL.D.Cargos, '$ Saldo Férias a Pagar' );

# --- Feeder cross-cubo: alimenta OPX.900.Gasto_Consolidado (origem FOL.100, contas de pessoal) ---
# 13º Salário (40000002) e Férias (40000003) são alimentados pelos componentes provisão + correção.
['$ Salário'] =>
   DB('OPX.900.Gasto_Consolidado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, !ALL.D.Centro_Custo, '40000001', 'FOL.100', '$ Valor Gasto');
['$ Provisão 13º Salário'] =>
   DB('OPX.900.Gasto_Consolidado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, !ALL.D.Centro_Custo, '40000002', 'FOL.100', '$ Valor Gasto');
['$ Correção Saldo 13º Salário'] =>
   DB('OPX.900.Gasto_Consolidado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, !ALL.D.Centro_Custo, '40000002', 'FOL.100', '$ Valor Gasto');
['$ Provisão Férias'] =>
   DB('OPX.900.Gasto_Consolidado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, !ALL.D.Centro_Custo, '40000003', 'FOL.100', '$ Valor Gasto');
['$ Correção Saldo Férias a Pagar'] =>
   DB('OPX.900.Gasto_Consolidado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, !ALL.D.Centro_Custo, '40000003', 'FOL.100', '$ Valor Gasto');
['$ INSS'] =>
   DB('OPX.900.Gasto_Consolidado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, !ALL.D.Centro_Custo, '40000004', 'FOL.100', '$ Valor Gasto');
['$ FGTS'] =>
   DB('OPX.900.Gasto_Consolidado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, !ALL.D.Centro_Custo, '40000005', 'FOL.100', '$ Valor Gasto');
['$ Plano de Saúde'] =>
   DB('OPX.900.Gasto_Consolidado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, !ALL.D.Centro_Custo, '40000006', 'FOL.100', '$ Valor Gasto');
['$ Vale Refeição'] =>
   DB('OPX.900.Gasto_Consolidado', !ALL.D.Ano, !ALL.D.Mes, !ALL.D.Versao, !ALL.D.Centro_Custo, '40000007', 'FOL.100', '$ Valor Gasto');
